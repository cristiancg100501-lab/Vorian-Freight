135 | 4 |                 .single()
136 | 4 |         ]);
137 | 4 | 
138 | 4 |         const freeDrivers    = freeResult.count ?? 0;
139 | 4 |         const busyDrivers    = busyResult.count ?? 0;
140 | 4 |         const totalFleet     = freeDrivers + busyDrivers;
141 | 4 |         const recentAccepted = acceptedResult.count ?? 0;
